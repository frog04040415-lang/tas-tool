<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TAS 滑雪實力鑑定</title>
    <style>
        :root { --tas-gold: #FFD700; --tas-orange: #FF8C00; --tas-dark: #1a1a1a; }
        body { font-family: 'PingFang TC', sans-serif; background-color: var(--tas-dark); color: white; margin: 0; padding: 20px; text-align: center; }
        .container { max-width: 500px; margin: auto; background: #222; padding: 30px; border-radius: 15px; border: 1px solid #444; }
        h2 { color: var(--tas-gold); margin-bottom: 20px; }
        .question { text-align: left; margin-bottom: 25px; }
        select, input, label { font-size: 16px; margin-top: 8px; color: #ddd; }
        select { width: 100%; padding: 10px; background: #333; border: 1px solid #555; color: white; }
        .checkbox-group { display: flex; flex-wrap: wrap; gap: 10px; }
        .btn { background: linear-gradient(45deg, var(--tas-orange), #ff4500); color: white; border: none; padding: 15px 30px; font-size: 18px; font-weight: bold; border-radius: 50px; cursor: pointer; margin-top: 20px; width: 100%; }
        /* 結果頁面樣式 */
        #result { display: none; }
        .rank-box { font-size: 48px; font-weight: bold; color: var(--tas-gold); margin: 20px 0; }
        .recommend-box { background: #333; padding: 15px; border-radius: 10px; margin-top: 20px; text-align: left; }
        .product-link { display: inline-block; background: var(--tas-gold); color: black; padding: 8px 15px; text-decoration: none; border-radius: 5px; font-weight: bold; margin-top: 10px; }
    </style>
</head>
<body>

<div class="container" id="quiz-container">
    <h2>TAS 滑雪實力鑑定</h2>
    <p>看看你在台灣滑雪者中的排名！</p>
    
    <div class="question">
        <label>1. 您的滑雪程度？</label>
        <select id="level">
            <option value="1">尚未滑過/打算嘗試</option>
            <option value="2">只滑過 1-2 次</option>
            <option value="3">初階 (落葉飄/纜車)</option>
            <option value="4">初中級 (練習 S Turn)</option>
            <option value="5">中級 (流暢紅線 S Turn)</option>
            <option value="6">進階 (挑戰黑線/非壓雪)</option>
            <option value="7">專家 (各種地形全能)</option>
        </select>
    </div>

    <div class="question">
        <label>2. 多久出國滑一次雪？</label>
        <select id="freq">
            <option value="3">每年 2 次以上</option>
            <option value="2">每年 1 次</option>
            <option value="1">兩年 1 次</option>
        </select>
    </div>

    <div class="question">
        <label>3. 目前擁有的裝備 (複選)</label>
        <div class="checkbox-group">
            <label><input type="checkbox" name="gear" value="goggle"> 雪鏡</label>
            <label><input type="checkbox" name="gear" value="helmet"> 頭盔</label>
            <label><input type="checkbox" name="gear" value="jacket"> 雪衣</label>
            <label><input type="checkbox" name="gear" value="pants"> 雪褲</label>
            <label><input type="checkbox" name="gear" value="protector"> 防摔褲</label>
        </div>
    </div>

    <button class="btn" onclick="showResult()">查看排名結果</button>
</div>

<div class="container" id="result">
    <h2>鑑定結果</h2>
    <p>你的實力已超越了</p>
    <div class="rank-box"><span id="winPercent">0</span>%</div>
    <p>的台灣滑雪者！</p>
    
    <div class="recommend-box" id="rec-content">
        </div>

    <button class="btn" onclick="location.reload()">重新檢測</button>
</div>

<script>
function showResult() {
    const level = parseInt(document.getElementById('level').value);
    const freq = parseInt(document.getElementById('freq').value);
    const gears = document.querySelectorAll('input[name="gear"]:checked');
    const gearList = Array.from(gears).map(g => g.value);

    // 根據你提供的問卷數據推算的權重邏輯
    let score = (level * 12) + (freq * 5) + (gearList.length * 2);
    let winPercent = 0;

    if (score > 80) winPercent = Math.floor(Math.random() * (99 - 90 + 1) + 90);
    else if (score > 60) winPercent = Math.floor(Math.random() * (89 - 70 + 1) + 70);
    else if (score > 40) winPercent = Math.floor(Math.random() * (69 - 40 + 1) + 40);
    else winPercent = Math.floor(Math.random() * (39 - 10 + 1) + 10);

    document.getElementById('winPercent').innerText = winPercent;
    document.getElementById('quiz-container').style.display = 'none';
    document.getElementById('result').style.display = 'block';

    // 產生建議
    let recHTML = `<strong>專家分析建議：</strong><br>`;
    if (level >= 5 && !gearList.includes('helmet')) {
        recHTML += `<p>你已具備中級以上實力，但在高速滑行中，頭部安全是關鍵。目前的裝備缺少【專業頭盔】，這能讓你更放心地挑戰黑線。</p>
                    <a href="/products/tas-helmet" class="product-link">查看 TAS 專業頭盔系列</a>`;
    } else if (level < 4) {
        recHTML += `<p>初學者最常遇到的挫折是摔倒的疼痛，建議配備【高效能防摔褲】，能大幅延長你的練習時數！</p>
                    <a href="/products/tas-protector" class="product-link">查看 TAS 防摔護具</a>`;
    } else {
        recHTML += `<p>你的表現非常出色！建議閱讀這篇專題：如何透過細微的姿態調整，進入前 5% 的專家領域？</p>
                    <a href="/blogs/news/advance-tips" class="product-link">閱讀技術文章</a>`;
    }
    document.getElementById('rec-content').innerHTML = recHTML;
}
</script>

</body>
</html>
